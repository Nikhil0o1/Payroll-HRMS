# ---- App ----
APP_NAME="HRMS Payroll"
ENVIRONMENT=development            # development | production
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ---- Database ----
# Dev (zero setup): SQLite. Production: PostgreSQL.
DATABASE_URL=sqlite:///./hrms.db
# DATABASE_URL=postgresql+psycopg2://hrms:hrms@localhost:5432/hrms

# ---- Security ----
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_super_secret_dev_key_only
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
STEP_UP_TOKEN_EXPIRE_MINUTES=5
# Dedicated Fernet key for bank account encryption at rest.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BANK_ACCOUNT_ENCRYPTION_KEY=
ALGORITHM=HS256

# ---- Brute-force protection ----
# Per-IP throttle is a coarse flood guard (generous, since an office may share
# one NAT IP). The real defence is the per-ACCOUNT lockout below.
RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_ATTEMPTS=50
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
ACCOUNT_LOCKOUT_THRESHOLD=8        # failed logins per account before temp lock (0 disables)
ACCOUNT_LOCKOUT_MINUTES=15

# ---- Company-domain allow-list ----
# Restrict signup, login, admin-invite, and admin-create-employee to addresses
# that end in one of these domains. Empty = no restriction (dev/demo). Accepts
# comma-separated values or a JSON array; a leading ``@`` is allowed.
# Examples:
#   ALLOWED_EMAIL_DOMAINS=yanthraa.com
#   ALLOWED_EMAIL_DOMAINS=yanthraa.com,yanthraa.in
#   ALLOWED_EMAIL_DOMAINS=["yanthraa.com","yanthraa.in"]
ALLOWED_EMAIL_DOMAINS=

# Logging: blank => DEBUG in dev, INFO in prod
LOG_LEVEL=
DEFAULT_CURRENCY=INR

# ---- Storage ----
STORAGE_BACKEND=local              # local | s3
STORAGE_DIR=./storage
# S3 (when STORAGE_BACKEND=s3)
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- Email ----
# `console` logs emails to the backend terminal (zero setup, perfect for dev).
# Switch to `smtp` and fill SMTP_* below to send real emails.
EMAIL_BACKEND=console              # console | smtp
EMAIL_FROM_ADDRESS=no-reply@company.com
EMAIL_FROM_NAME="HRMS Payroll"
# Public URL of the deployed frontend. Embedded in onboarding/welcome emails
# as the "Sign in" link. In production this MUST be the real public URL —
# the backend will refuse to start if it still points at localhost.
APP_PUBLIC_URL=http://localhost:5173

# SMTP (only used when EMAIL_BACKEND=smtp)
# Gmail:    SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USE_TLS=true   (use an App Password)
# SendGrid: SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USERNAME=apikey  SMTP_PASSWORD=<sg-key>
# AWS SES:  SMTP_HOST=email-smtp.<region>.amazonaws.com  SMTP_PORT=587  SMTP_USE_TLS=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false                 # true for legacy port 465; false for STARTTLS on 587

# ---- Payroll / policy ----
WORKDAY_START="09:30"              # late threshold
FULL_DAY_MINUTES=480               # 8h
HALF_DAY_MINUTES=240
WEEKEND_DAYS=[5,6]                 # Sat, Sun (Mon=0)
# Maker-checker: a payroll run must be approved by a different user than its
# creator. Set false only for single-admin teams.
PAYROLL_REQUIRE_SEPARATE_APPROVER=true

# ---- Seed / bootstrap ----
FIRST_SUPERADMIN_EMAIL=admin@company.com
FIRST_SUPERADMIN_PASSWORD=Admin@12345
# Auto-bootstrap roles, leave types, holidays, and the admin user on app startup.
# Set to false in multi-replica deployments if you prefer a dedicated init job.
AUTO_BOOTSTRAP_ON_STARTUP=true
