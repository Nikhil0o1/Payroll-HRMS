# Frontend build-time config (Vite). Copy to .env.local for local overrides.
#
# Leave this UNSET for local dev — the app then uses the relative "/api/v1"
# path, which Vite's dev server proxies to http://localhost:8000
# (see vite.config.ts).
#
# In production (Vercel) set this to your deployed backend's API base, e.g.
#   VITE_API_BASE_URL=https://hrms-backend.onrender.com/api/v1
VITE_API_BASE_URL=
